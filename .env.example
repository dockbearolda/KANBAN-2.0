# Connexion PostgreSQL — fournie automatiquement par le plugin Railway PostgreSQL.
# En local : pointe vers ta base locale.
DATABASE_URL=postgresql://user:password@localhost:5432/atelier_olda

# Mot de passe d'accès partagé (Basic Auth). Si absent → accès ouvert (dev local).
APP_PASSWORD=change-moi

# Port d'écoute. Railway le fournit automatiquement ; en local, défaut = 3000.
PORT=3000

# Clé API Anthropic (console.anthropic.com) — extraction des commandes vocales.
# Si absente, l'appli fonctionne mais la dictée vocale est désactivée.
ANTHROPIC_API_KEY=sk-ant-...
